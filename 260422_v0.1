<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title>유아른 팝업 계산기</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/pretendard/dist/web/static/pretendard.css">
  <style>
    :root {
      --bg: #f5f5f3;
      --card: #ffffff;
      --line: #e8e8e4;
      --fg: #1a1a18;
      --muted: #8a8a84;
      --accent: #2d5a3d;
      --accent-light: #e8f0ea;
      --accent-hover: #234a31;
      --warn: #c8552a;
      --r-xl: 16px;
      --r-md: 12px;
      --r-sm: 8px;
      --shadow: 0 2px 12px rgba(0,0,0,0.06);
      --shadow-hover: 0 6px 24px rgba(0,0,0,0.1);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--fg);
      font-family: Pretendard, -apple-system, "Apple SD Gothic Neo", "Malgun Gothic", sans-serif;
      font-size: 13.5px;
      line-height: 1.55;
      min-height: 100dvh;
    }

    /* ── 헤더 ── */
    .header {
      background: var(--fg);
      color: #fff;
      padding: 10px 16px;
      display: flex;
      align-items: center;
      gap: 10px;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .header-logo {
      font-size: 15px;
      font-weight: 800;
      letter-spacing: -0.3px;
      color: #fff;
    }
    .header-sub {
      font-size: 11.5px;
      color: rgba(255,255,255,0.5);
      margin-left: auto;
    }

    /* ── 레이아웃 ── */
    .page {
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 12px;
      max-width: 1200px;
      margin: 0 auto;
      padding: 10px 12px;
      align-items: start;
    }

    /* ── 카테고리 ── */
    .cat { margin-bottom: 12px; }
    .cat-title {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 6px;
      padding-bottom: 5px;
      border-bottom: 1px solid var(--line);
    }

    /* ── 상품 그리드 ── */
    .grid {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 6px;
    }

    /* ── 상품 카드 ── */
    .product {
      background: var(--card);
      border: 1.5px solid var(--line);
      border-radius: var(--r-sm);
      padding: 7px;
      cursor: pointer;
      transition: border-color 0.15s, box-shadow 0.15s, transform 0.1s;
      display: flex;
      flex-direction: column;
      gap: 4px;
      user-select: none;
    }
    .product:hover {
      border-color: #c0c0b8;
      box-shadow: var(--shadow-hover);
      transform: translateY(-1px);
    }
    .product.selected {
      border-color: var(--accent);
      background: var(--accent-light);
      box-shadow: 0 0 0 3px rgba(45,90,61,0.12);
    }

    .p-thumb {
      width: 100%;
      aspect-ratio: 1;
      border-radius: var(--r-sm);
      object-fit: cover;
      background: #f0f0ec;
      display: block;
    }
    .p-name {
      font-size: 10.5px;
      font-weight: 700;
      line-height: 1.3;
      color: var(--fg);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .p-price {
      font-size: 10.5px;
      font-weight: 600;
      color: var(--accent);
    }

    .qty-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: #f5f5f3;
      border-radius: 5px;
      padding: 1px;
      margin-top: auto;
    }
    .qty-btn {
      width: 22px;
      height: 22px;
      border: none;
      background: transparent;
      border-radius: 4px;
      cursor: pointer;
      font-size: 14px;
      font-weight: 700;
      color: var(--fg);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.1s;
      flex-shrink: 0;
    }
    .qty-btn:hover { background: var(--line); }
    .qty-badge {
      flex: 1;
      text-align: center;
      font-size: 11px;
      font-weight: 800;
      color: var(--fg);
    }
    .product.selected .qty-row { background: rgba(45,90,61,0.08); }

    /* ── 장바구니 패널 ── */
    .panel {
      background: var(--card);
      border: 1.5px solid var(--line);
      border-radius: var(--r-xl);
      padding: 16px;
      position: sticky;
      top: 60px;
      max-height: calc(100dvh - 76px);
      overflow-y: auto;
      box-shadow: var(--shadow);
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .panel-title {
      font-size: 14px;
      font-weight: 800;
      letter-spacing: -0.2px;
    }

    /* 빈 장바구니 */
    .cart-empty {
      text-align: center;
      padding: 32px 16px;
      color: var(--muted);
      font-size: 13px;
      background: #fafaf8;
      border-radius: var(--r-md);
      border: 1.5px dashed var(--line);
    }
    .cart-empty-icon { font-size: 28px; margin-bottom: 8px; }

    /* 장바구니 아이템 */
    .cart-items { display: flex; flex-direction: column; gap: 6px; }
    .cart-item {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px;
      background: #fafaf8;
      border-radius: var(--r-sm);
      border: 1px solid var(--line);
    }
    .ci-name {
      flex: 1;
      font-size: 12px;
      font-weight: 600;
      line-height: 1.3;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }
    .ci-qty {
      display: flex;
      align-items: center;
      gap: 4px;
      flex-shrink: 0;
    }
    .ci-btn {
      width: 22px;
      height: 22px;
      border: 1px solid var(--line);
      background: var(--card);
      border-radius: 5px;
      cursor: pointer;
      font-weight: 800;
      font-size: 13px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.1s;
    }
    .ci-btn:hover { background: var(--accent-light); }
    .ci-qty-num { min-width: 20px; text-align: center; font-weight: 700; font-size: 13px; }
    .ci-price {
      font-size: 12px;
      font-weight: 700;
      color: var(--accent);
      flex-shrink: 0;
      min-width: 54px;
      text-align: right;
    }

    /* 합계 */
    .cart-totals {
      border-top: 1.5px solid var(--line);
      padding-top: 10px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .total-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      font-size: 13px;
    }
    .total-row.grand {
      font-size: 15px;
      font-weight: 800;
      color: var(--fg);
      margin-top: 2px;
    }
    .total-row.grand .val { color: var(--accent); }
    .total-label { color: var(--muted); font-size: 12px; }
    .total-row.grand .total-label { color: var(--fg); font-size: 15px; font-weight: 800; }

    /* 사은품 */
    .gift-box {
      background: var(--accent-light);
      border: 1.5px solid var(--accent);
      border-radius: var(--r-sm);
      padding: 10px 12px;
    }
    .gift-title {
      font-size: 11px;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: 0.04em;
      margin-bottom: 5px;
    }
    .gift-list { display: flex; flex-direction: column; gap: 3px; }
    .gift-item {
      font-size: 12px;
      font-weight: 600;
      color: var(--accent);
      display: flex;
      align-items: center;
      gap: 5px;
    }
    .gift-item::before { content: "🎁"; font-size: 11px; }
    .gift-none { font-size: 12px; color: var(--muted); }

    /* 결제 버튼 */
    .pay-btn {
      width: 100%;
      background: var(--fg);
      color: #fff;
      border: none;
      border-radius: var(--r-md);
      padding: 14px;
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      letter-spacing: -0.2px;
      transition: background 0.15s, transform 0.1s;
    }
    .pay-btn:hover { background: #2e2e2a; }
    .pay-btn:active { transform: scale(0.98); }
    .pay-btn:disabled { background: #ccc; cursor: not-allowed; }
    .pay-note {
      text-align: center;
      font-size: 11px;
      color: var(--muted);
      margin-top: -4px;
    }

    /* 로딩 */
    .loading {
      text-align: center;
      padding: 40px;
      color: var(--muted);
      font-size: 13px;
    }
    .spinner {
      width: 28px; height: 28px;
      border: 3px solid var(--line);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
      margin: 0 auto 12px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* 모바일 */
    @media (max-width: 800px) {
      .page {
        grid-template-columns: 1fr;
        padding: 12px;
      }
      .grid { grid-template-columns: repeat(3, 1fr); }
      .panel {
        position: static;
        max-height: none;
        order: -1;
      }
    }
    @media (max-width: 480px) {
      .grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>
<body>

<header class="header">
  <div class="header-logo">유아른 · ureun</div>
  <div class="header-sub">팝업 주문서</div>
</header>

<div class="page">
  <main id="main">
    <div class="loading"><div class="spinner"></div>상품을 불러오는 중...</div>
  </main>

  <aside class="panel">
    <div class="panel-title">선택한 상품</div>

    <div id="cartEmpty" class="cart-empty">
      <div class="cart-empty-icon">🛒</div>
      아직 선택된 상품이 없어요
    </div>

    <div id="cartWrap" style="display:none; flex-direction:column; gap:12px;">
      <div id="cartItems" class="cart-items"></div>

      <div class="cart-totals">
        <div class="total-row">
          <span class="total-label">총 수량</span>
          <span id="totalQty" class="val">0개</span>
        </div>
        <div class="total-row grand">
          <span class="total-label">합계</span>
          <span id="grand" class="val">0원</span>
        </div>
      </div>

      <div id="giftBox" class="gift-box">
        <div class="gift-title">🎁 사은품</div>
        <div id="giftList" class="gift-list">
          <span class="gift-none">없음</span>
        </div>
      </div>

      <button id="payBtn" class="pay-btn">주문 제출</button>
      <p class="pay-note">제출 후 모든 항목이 초기화됩니다</p>
    </div>
  </aside>
</div>

<!-- 폼 전송용 -->
<form id="orderForm" method="POST"
  action="https://docs.google.com/forms/d/e/1FAIpQLSfb_tyiUqwoIp8E_KTReuQTe-bsjnuf6pD2n_tk8y7_TX7EMA/formResponse"
  target="hiddenFrame" style="display:none"></form>
<iframe name="hiddenFrame" style="display:none"></iframe>

<script>
  const SHEET_ID = "1QpbkNSpsAoKhgMbCtHUhz97D5epuUqoGt7esf1-u-fw";
  const IMG_BASE = "images-v2";

  // 고정 entry ID
  const ENTRY_TIME     = "entry.641954362";
  const ENTRY_QTY      = "entry.2003813706";
  const ENTRY_AMOUNT   = "entry.1401654522";

  // 사은품 규칙 (sheet2에서 동적 로드)
  let giftRules = [];   // [{ minAmt, name, entryId }, ...]
  let productMap = {};  // key → { name, price, entryId }
  const cart = {};

  // ── 데이터 로드 ──────────────────────────────────────────
  async function loadAll() {
    const [prodRows, giftRows] = await Promise.all([
      fetch(`https://opensheet.elk.sh/${SHEET_ID}/sheet1`).then(r => r.json()),
      fetch(`https://opensheet.elk.sh/${SHEET_ID}/sheet2`).then(r => r.json()),
    ]);

    // 숫자 파싱 헬퍼
    const parseNum = str => Number(String(str || "0").replace(/[^0-9]/g, ""));

    // 사은품 규칙 파싱
    giftRules = giftRows.map(r => ({
      minAmt:  parseNum(r["구매 조건"]),
      name:    r["상품명"] || "",
      entryId: r["entry ID"] || "",
    })).filter(g => g.name).sort((a, b) => a.minAmt - b.minAmt);

    // 상품 렌더링
    const categories = {};
    prodRows.forEach((r, i) => {
      const cat = r["분류"] || "기타";
      if (!categories[cat]) categories[cat] = [];
      const price = parseNum(r["판매가"]);
      const entryId = r["entry ID"] || "";
      const imgVal = r["이미지"] || "";
      const imgSrc = imgVal.startsWith("http") ? imgVal : `${IMG_BASE}/${imgVal}`;
      const key = `p${i}`;
      productMap[key] = { name: r["상품명"], price, entryId, imgSrc };
      categories[cat].push(key);
    });

    const main = document.getElementById("main");
    main.innerHTML = "";

    Object.entries(categories).forEach(([catName, keys]) => {
      const sec = document.createElement("section");
      sec.className = "cat";
      sec.innerHTML = `<div class="cat-title">${catName}</div><div class="grid"></div>`;
      const grid = sec.querySelector(".grid");

      keys.forEach(key => {
        const p = productMap[key];
        const card = document.createElement("div");
        card.className = "product";
        card.id = `card-${key}`;
        card.innerHTML = `
          <img class="p-thumb" src="${p.imgSrc}" alt="${p.name}" onerror="this.style.background='#e8e8e4';this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 1 1%22/>'">
          <div class="p-name">${p.name}</div>
          <div class="p-price">${p.price.toLocaleString()}원</div>
          <div class="qty-row">
            <button class="qty-btn" data-act="minus">−</button>
            <span class="qty-badge" id="badge-${key}">0</span>
            <button class="qty-btn" data-act="plus">＋</button>
          </div>`;
        card.addEventListener("click", e => {
          const act = e.target?.dataset?.act;
          if (act === "minus") {
            if ((cart[key] || 0) > 0) cart[key]--;
            if (cart[key] === 0) delete cart[key];
          } else {
            cart[key] = (cart[key] || 0) + 1;
          }
          render();
        });
        grid.appendChild(card);
      });

      main.appendChild(sec);
    });

    render();
  }

  // ── 렌더 ─────────────────────────────────────────────────
  function render() {
    // 카드 뱃지 & 선택 상태
    Object.keys(productMap).forEach(k => {
      const badge = document.getElementById(`badge-${k}`);
      const card = document.getElementById(`card-${k}`);
      if (badge) badge.textContent = String(cart[k] || 0);
      if (card) {
        if (cart[k] > 0) card.classList.add("selected");
        else card.classList.remove("selected");
      }
    });

    const keys = Object.keys(cart).filter(k => cart[k] > 0);
    const empty = document.getElementById("cartEmpty");
    const wrap = document.getElementById("cartWrap");

    if (!keys.length) {
      empty.style.display = "";
      wrap.style.display = "none";
      return;
    }
    empty.style.display = "none";
    wrap.style.display = "flex";

    // 장바구니 아이템
    let total = 0, totalQty = 0;
    document.getElementById("cartItems").innerHTML = keys.map(k => {
      const p = productMap[k], q = cart[k], sub = q * p.price;
      total += sub; totalQty += q;
      return `<div class="cart-item" data-key="${k}">
        <div class="ci-name">${p.name}</div>
        <div class="ci-qty">
          <button class="ci-btn" data-act="minus">−</button>
          <span class="ci-qty-num">${q}</span>
          <button class="ci-btn" data-act="plus">＋</button>
        </div>
        <div class="ci-price">${sub.toLocaleString()}원</div>
      </div>`;
    }).join("");

    document.getElementById("grand").textContent = `${total.toLocaleString()}원`;
    document.getElementById("totalQty").textContent = `${totalQty}개`;

    // 사은품 계산 (중복 증정)
    const earned = giftRules.filter(g => total >= g.minAmt);
    const giftList = document.getElementById("giftList");
    const giftTitle = document.querySelector(".gift-title");
    if (earned.length) {
      giftTitle.textContent = `🎁 사은품 ${earned.length}종`;
      giftList.innerHTML = earned.map(g =>
        `<div class="gift-item">${g.name.replace(/^\[사은품\]\s*/,'')}</div>`
      ).join("");
    } else {
      giftTitle.textContent = `🎁 사은품`;
      giftList.innerHTML = `<span class="gift-none">없음</span>`;
    }
  }

  // 장바구니 패널 버튼 이벤트
  document.getElementById("cartItems").addEventListener("click", e => {
    const btn = e.target.closest(".ci-btn");
    if (!btn) return;
    const key = e.target.closest("[data-key]")?.dataset?.key;
    if (!key) return;
    if (btn.dataset.act === "plus") cart[key] = (cart[key] || 0) + 1;
    else {
      if ((cart[key] || 0) > 0) cart[key]--;
      if (cart[key] === 0) delete cart[key];
    }
    render();
  });

  // ── 결제 제출 ─────────────────────────────────────────────
  document.getElementById("payBtn").addEventListener("click", () => {
    const keys = Object.keys(cart).filter(k => cart[k] > 0);
    if (!keys.length) { alert("상품을 선택해주세요."); return; }

    const formEl = document.getElementById("orderForm");
    formEl.innerHTML = "";

    const addInput = (name, value) => {
      const inp = document.createElement("input");
      inp.type = "hidden"; inp.name = name; inp.value = value;
      formEl.appendChild(inp);
    };

    // 시간
    addInput(ENTRY_TIME, new Date().toISOString());

    // 상품별 수량
    keys.forEach(k => {
      const p = productMap[k];
      if (p.entryId) addInput(p.entryId, cart[k]);
    });

    // 사은품 (받는 경우 1, 없으면 0)
    const total = keys.reduce((sum, k) => sum + cart[k] * productMap[k].price, 0);
    const totalQty = keys.reduce((sum, k) => sum + cart[k], 0);
    giftRules.forEach(g => {
      if (g.entryId) addInput(g.entryId, total >= g.minAmt ? 1 : 0);
    });

    // 총 수량 / 결제금액
    addInput(ENTRY_QTY, totalQty);
    addInput(ENTRY_AMOUNT, total);

    formEl.submit();

    // 초기화
    Object.keys(cart).forEach(k => delete cart[k]);
    render();
    window.scrollTo({ top: 0, behavior: "smooth" });
    alert("주문이 제출되었습니다 🎉");
  });

  loadAll();
</script>
</body>
</html>
